# Supabase Configuration
# Get these values from your Supabase project settings

# Public URL for your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public anonymous key for client-side access
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key for server-side access (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Direct database connection string
POSTGRES_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# Pooled connection URL (for serverless)
POSTGRES_URL_NON_POOLING=postgresql://postgres:password@db.supabase.co:6543/postgres

# Prisma ORM connection URL (optional, if using Prisma)
POSTGRES_PRISMA_URL=postgresql://postgres:password@db.supabase.co:6543/postgres

# Database credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_HOST=db.supabase.co
POSTGRES_DATABASE=postgres

# JWT Secret for Supabase Auth
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase

# Additional configuration (optional)
NODE_ENV=development
